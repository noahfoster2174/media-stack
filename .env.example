# Copy to .env and fill in. Secrets are gitignored; this template is safe to commit.

PUID=501
PGID=20
TZ=America/New_York
MULLVAD_ACCOUNT=

# Service credentials (used by server.py and download-movie.sh)
RADARR_API_KEY=
QBT_USER=admin
QBT_PASS=
TMDB_API_KEY=

# Plex (for watched sync)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Anthropic (legacy/unused — chat now runs on the local Ollama model below)
ANTHROPIC_API_KEY=

# Local Ollama (Chat tab) — run `ollama pull qwen2.5:3b`; served at :11434
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# Set to 1 to also serve on your LAN (phone access). Needs `mullvad lan set allow` if VPN is on.
BIND_LAN=0
